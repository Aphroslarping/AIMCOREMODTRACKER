-- Safe HTTP request wrapper (supports syn.request, http.request, request)
local function httpRequest(options)
    if syn and syn.request then
        return syn.request(options)
    elseif http and http.request then
        return http.request(options)
    elseif request then
        return request(options)
    else
        error("[AimCore] No HTTP function available in your executor!")
    end
end

-- Format seconds into HH:MM:SS
local function formatUptime(seconds)
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = seconds % 60
    return string.format("%02d:%02d:%02d", h, m, s)
end

-- Get current timestamp string
local function getTimestamp()
    return os.date("%Y-%m-%d %H:%M:%S UTC")
end

-- ════════════════════════════════════════════════════
--           ROBLOX PRESENCE API FETCH
-- ════════════════════════════════════════════════════

local function fetchPresences()
    -- Collect all UserIds
    local userIds = {}
    for _, mod in ipairs(MODS) do
        table.insert(userIds, mod.UserId)
    end

    local body = HttpService:JSONEncode({ userIds = userIds })

    local ok, response = pcall(function()
        return httpRequest({
            Url     = "https://presence.roblox.com/v1/presence/users",
            Method  = "POST",
            Headers = {
                ["Content-Type"] = "application/json",
                ["Accept"]       = "application/json",
            },
            Body = body,
        })
    end)

    if not ok then
        warn("[AimCore] Failed to reach Roblox Presence API: " .. tostring(response))
        return nil
    end

    if response.StatusCode ~= 200 then
        warn("[AimCore] Presence API returned status " .. tostring(response.StatusCode))
        return nil
    end

    local decoded = HttpService:JSONDecode(response.Body)
    return decoded.userPresences
end

