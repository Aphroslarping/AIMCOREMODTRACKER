-- Use a Heartbeat loop to avoid yielding the main thread
RunService.Heartbeat:Connect(function(dt)
    ticker = ticker + dt

    -- Only run check every CHECK_INTERVAL seconds
    if ticker < CHECK_INTERVAL and not firstRun then return end
    ticker   = 0
    firstRun = false

    -- Spawn in new thread so we don't block game
    task.spawn(function()
        local presences = fetchPresences()
        if not presences then
            warn("[AimCore] Skipping update — could not fetch presences.")
            return
        end

        local changed = detectChanges(presences)

        -- Always update on first run, then only on changes
        -- (or you can always update by removing the 'changed' check below)
        if changed or webhookMessageId == nil then
            local embed = buildEmbedContent(presences)
            sendOrEditWebhook(embed)
        end
    end)
end)
