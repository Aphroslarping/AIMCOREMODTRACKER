--           BUILD DISCORD EMBED CONTENT
-- ════════════════════════════════════════════════════

local function buildEmbedContent(presences)
    -- Map userId → presenceType for fast lookup
    local presenceMap = {}
    for _, p in ipairs(presences) do
        presenceMap[p.userId] = p.userPresenceType or 0
    end

    -- Separate mods into buckets
    local ingame  = {}
    local online  = {}
    local offline = {}

    for _, mod in ipairs(MODS) do
        local pType = presenceMap[mod.UserId] or 0
        local bucket
        if pType == 2 or pType == 3 then
            bucket = ingame
        elseif pType == 1 then
            bucket = online
        else
            bucket = offline
        end
        table.insert(bucket, { mod = mod, pType = pType })
    end

    -- Build fields string
    local lines = {}

    -- INGAME section
    if #ingame > 0 then
        table.insert(lines, "🎮 **── IN-GAME ──**")
        for _, entry in ipairs(ingame) do
            local info = PRESENCE_MAP[entry.pType] or PRESENCE_MAP[0]
            table.insert(lines, string.format(
                "%s `USERNAME:` **%s**\n   `USERID:  ` **%d**\n   `STATUS:  ` **%s**",
                info.emoji,
                entry.mod.Username,
                entry.mod.UserId,
                info.label
            ))
        end
    end

    -- ONLINE section
    if #online > 0 then
        if #lines > 0 then table.insert(lines, "") end
        table.insert(lines, "🟢 **── ONLINE ──**")
        for _, entry in ipairs(online) do
            local info = PRESENCE_MAP[entry.pType] or PRESENCE_MAP[0]
            table.insert(lines, string.format(
                "%s `USERNAME:` **%s**\n   `USERID:  ` **%d**\n   `STATUS:  ` **%s**",
                info.emoji,
                entry.mod.Username,
                entry.mod.UserId,
                info.label
            ))
        end
    end

    -- OFFLINE section
    if #offline > 0 then
        if #lines > 0 then table.insert(lines, "") end
        table.insert(lines, "⚫ **── OFFLINE ──**")
        for _, entry in ipairs(offline) do
            local info = PRESENCE_MAP[entry.pType] or PRESENCE_MAP[0]
            table.insert(lines, string.format(
                "%s `USERNAME:` **%s**\n   `USERID:  ` **%d**\n   `STATUS:  ` **%s**",
                info.emoji,
                entry.mod.Username,
                entry.mod.UserId,
                info.label
            ))
        end
    end

    -- Summary counts
    local summary = string.format(
        "🎮 InGame: **%d** | 🟢 Online: **%d** | ⚫ Offline: **%d**",
        #ingame, #online, #offline
    )

    -- Uptime
    local uptime = formatUptime(os.time() - sessionStart)

    -- Assemble embed
    local embed = {
        title       = "🔍 AimCore Mod Tracker — Live Status",
        description = table.concat(lines, "\n"),
        color       = 0x9B59B6, -- Purple to match AimCore theme
        footer      = {
            text = string.format(
                "Made by the AimCore Owner @bqlsh  •  Uptime: %s  •  %s",
                uptime,
                getTimestamp()
            )
        },
        fields = {
            {
                name   = "📊 Summary",
                value  = summary,
                inline = false,
            }
        }
    }

    return embed
end

-- ════════════════════════════════════════════════════
--           DISCORD WEBHOOK SEND / EDIT
-- ════════════════════════════════════════════════════

local function sendOrEditWebhook(embed)
    local payload = HttpService:JSONEncode({
        username   = BOT_USERNAME,
        avatar_url = BOT_AVATAR,
        embeds     = { embed },
    })

    -- If we have a message ID, PATCH (edit) it — no spam
    if webhookMessageId then
        local ok, res = pcall(function()
            return httpRequest({
                Url     = WEBHOOK_URL .. "/messages/" .. webhookMessageId,
                Method  = "PATCH",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = payload,
            })
        end)
        if not ok then
            warn("[AimCore] Failed to edit webhook message: " .. tostring(res))
            webhookMessageId = nil -- Reset so it tries to create a new one
        end
    else
        -- POST new message with ?wait=true to get message ID back
        local ok, res = pcall(function()
            return httpRequest({
                Url     = WEBHOOK_URL .. "?wait=true",
                Method  = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = payload,
            })
        end)

        if ok and res and res.StatusCode == 200 then
            local data = HttpService:JSONDecode(res.Body)
            webhookMessageId = data.id
            print("[AimCore] Webhook message created. ID: " .. tostring(webhookMessageId))
        else
            warn("[AimCore] Failed to send initial webhook.")
        end
    end
end

-- ════════════════════════════════════════════════════
--           CHANGE DETECTION
-- ════════════════════════════════════════════════════

-- Returns true if any status changed (forces a webhook update)
local function detectChanges(presences)
    local changed = false
    for _, p in ipairs(presences) do
        local uid   = p.userId
        local pType = p.userPresenceType or 0
        if previousStatuses[uid] ~= pType then
            local prev    = PRESENCE_MAP[previousStatuses[uid] or 0]
            local current = PRESENCE_MAP[pType]
            -- Find username for the log
            local uname = tostring(uid)
            for _, mod in ipairs(MODS) do
                if mod.UserId == uid then
                    uname = mod.Username
                    break
                end
            end
            print(string.format(
                "[AimCore] STATUS CHANGE → %s (%d): %s → %s",
                uname, uid,
                prev and prev.label or "?",
                current and current.label or "?"
            ))
            previousStatuses[uid] = pType
            changed = true
        end
    end
    return changed
end

